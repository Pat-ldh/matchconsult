# ── Choix du backend LLM (une seule option à la fois) ────────────────────────

# Option 1 : Mode démo — aucun LLM, données fictives, aucune clé nécessaire
DEMO_MODE=true

# Option 2 : Groq (gratuit) — https://console.groq.com → "Create API Key"
# GROQ_API_KEY=gsk_...
# DEMO_MODE=false

# Option 3 : Anthropic Claude (payant)
# ANTHROPIC_API_KEY=sk-ant-...
# DEMO_MODE=false

# ── Paramètres généraux ───────────────────────────────────────────────────────
CV_DIRECTORY=./data/cvs
CLAUDE_MODEL=claude-sonnet-4-6
HAIKU_MODEL=claude-haiku-4-5-20251001
GROQ_MODEL=llama-3.3-70b-versatile
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
